{
  "name": "viewfly",
  "version": "0.0.1",
  "private": true,
  "description": "Viewfly 组件式 UI 框架与本仓库各子包的源码与示例（monorepo）。",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @viewfly/playground dev",
    "start": "pnpm run dev",
    "build": "pnpm -r --filter \"./packages/*\" run build:lib",
    "build:playground": "pnpm --filter @viewfly/playground build",
    "preview:playground": "pnpm --filter @viewfly/playground preview",
    "lint-staged": "lint-staged",
    "lint": "eslint \"packages/**/*.{ts,tsx}\" --max-warnings 0",
    "test": "cross-env env=test jest",
    "test:watch": "cross-env env=test jest --watch",
    "test-c": "cross-env env=test jest --coverage",
    "benchmark": "pnpm --filter @viewfly/benchmark benchmark",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --max-warnings 0"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "author": "tanbo",
  "license": "MIT",
  "keywords": [
    "viewfly",
    "framework",
    "jsx",
    "monorepo"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-location-mock": "^2.0.0",
    "lint-staged": "^15.4.3",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.2.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/viewfly/viewfly.git"
  }
}
