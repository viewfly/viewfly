{
  "compilerOptions": {
    "declaration": false,
    "useDefineForClassFields": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "target": "es6",
    "strict": true,
    "module": "es2020",
    "moduleResolution": "node",
    "inlineSourceMap": true,
    "inlineSources": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "outDir": "dist/",
    "downlevelIteration": true,
    "paths": {
      "@viewfly/core": [
        "./src/index.ts"
      ],
      "@viewfly/core/jsx-runtime": [
        "./src/jsx-runtime.ts"
      ]
    }
  },
  "include": [
    "src"
  ]
}
