{
  "name": "@viewfly/platform-browser",
  "version": "2.1.0",
  "description": "This project is used to enable the Viewfly framework to run in a browser.",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build:lib": "rimraf dist && pnpm run build && node -e \"const fs=require('node:fs');if(fs.existsSync('dist/public-api.d.ts'))fs.renameSync('dist/public-api.d.ts','dist/index.d.ts')\" && rimraf dist/platform-browser",
    "build": "vite build --config vite.config.ts",
    "publish:lib": "npm run build:lib && npm publish --access=public"
  },
  "files": [
    "dist/**/*"
  ],
  "license": "MIT",
  "keywords": [],
  "dependencies": {
    "@viewfly/core": "^2.1.0",
    "csstype": "^3.1.3"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tslib": "^2.8.1",
    "typescript": "~5.8.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  },
  "author": {
    "name": "Tanbo",
    "email": "tanbohb@qq.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viewfly/viewfly.git"
  },
  "bugs": {
    "url": "https://github.com/viewfly/viewfly/issues"
  }
}
