{
  "compilerOptions": {
    "target": "es6",
    "module": "esnext",
    "strict": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "useDefineForClassFields": true,
    "lib": ["esnext", "dom"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": "./",
    "jsx": "react-jsx",
    "jsxImportSource": "@viewfly/core",
    "types": ["vite/client"]
  },
  "include": ["src", "types.d.ts"]
}
