{
  "name": "viewfly",
  "version": "0.0.1",
  "private": true,
  "description": "Viewfly 组件式 UI 框架与本仓库各子包的源码与示例（monorepo）。",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @viewfly/playground dev",
    "start": "pnpm run dev",
    "build": "pnpm -r --filter \"./packages/*\" run build:lib",
    "build:playground": "pnpm --filter @viewfly/playground build",
    "preview:playground": "pnpm --filter @viewfly/playground preview",
    "lint-staged": "lint-staged",
    "lint": "eslint packages --ext .ts,.tsx --max-warnings 0",
    "test": "cross-env env=test jest",
    "test:watch": "cross-env env=test jest --watch",
    "test-c": "cross-env env=test jest --coverage",
    "prepare": "husky install"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --max-warnings 0"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "author": "tanbo",
  "license": "MIT",
  "keywords": [
    "viewfly",
    "framework",
    "jsx",
    "monorepo"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "@types/node": "^18.11.11",
    "@typescript-eslint/eslint-plugin": "^5.8.0",
    "@typescript-eslint/parser": "^5.8.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.5.0",
    "husky": "^8.0.1",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jest-location-mock": "^1.0.10",
    "lint-staged": "^13.0.2",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.6",
    "vite": "^5.4.9",
    "vite-plugin-dts": "^4.5.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/viewfly/viewfly.git"
  }
}
