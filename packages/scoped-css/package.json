{
  "name": "@viewfly/scoped-css",
  "version": "2.1.0",
  "description": "A library for supporting scoped style sheets in the Viewfly framework。",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build:lib": "rimraf dist && pnpm run build && node -e \"const fs=require('node:fs');if(fs.existsSync('dist/public-api.d.ts'))fs.renameSync('dist/public-api.d.ts','dist/index.d.ts')\" && rimraf dist/scoped-css",
    "build": "vite build --config vite.config.ts",
    "publish:lib": "npm run build:lib && npm publish --access=public"
  },
  "files": [
    "dist/**/*"
  ],
  "license": "MIT",
  "keywords": [],
  "dependencies": {
    "@viewfly/core": "^2.1.0"
  },
  "devDependencies": {
    "rimraf": "^3.0.2",
    "tslib": "^2.6.0"
  },
  "author": {
    "name": "Tanbo",
    "email": "tanbohb@qq.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viewfly/viewfly.git"
  },
  "bugs": {
    "url": "https://github.com/viewfly/viewfly.git/issues"
  },
  "gitHead": "b66ca589f7662cd518fc2e5955b3e3ff9de83f94"
}
