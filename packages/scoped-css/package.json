{
  "name": "@viewfly/scoped-css",
  "version": "2.2.0",
  "description": "A library for supporting scoped style sheets in the Viewfly framework。",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build:lib": "rimraf dist && pnpm run build && rimraf dist/scoped-css",
    "build": "vite build --config vite.config.ts",
    "publish:lib": "npm run build:lib && npm publish --access=public"
  },
  "files": [
    "dist/**/*"
  ],
  "license": "MIT",
  "keywords": [],
  "dependencies": {
    "@viewfly/core": "^2.2.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tslib": "^2.8.1",
    "typescript": "~5.8.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  },
  "author": {
    "name": "Tanbo",
    "email": "tanbohb@qq.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viewfly/viewfly.git"
  },
  "bugs": {
    "url": "https://github.com/viewfly/viewfly/issues"
  }
}
